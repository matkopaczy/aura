# Skopiuj do .env i uzupełnij. Sekrety NIGDY w repo (§9).
APP_ENV=development
DATABASE_URL=postgresql+psycopg://aura:aura@localhost:5432/aura
SECRET_KEY=wygeneruj-np-openssl-rand-hex-32
ACCESS_TOKEN_MINUTES=30
CORS_ORIGINS=["http://localhost:3000"]
DASHBOARD_URL=http://localhost:3000

# E-mail (§8.2). Lokalnie: python -m aiosmtpd -n -l localhost:1025
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Aura <no-reply@localhost>

# Abonament (§5, §12 pkt 4)
TRIAL_DAYS=30
DEFAULT_PRICE_PER_PROPERTY=49
BILLING_CURRENCY=PLN

# Monitoring błędów (§6.1) — puste = Sentry wyłączony
SENTRY_DSN=
